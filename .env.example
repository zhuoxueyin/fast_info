# ============================================================
# fastInfo · 环境变量模板
# ============================================================
# 用法:
#   1. 复制本文件为 .env(本地开发)/ docker/env.docker.local(Docker)
#      cp .env.example .env
#      cp docker/env.docker.local.example docker/env.docker.local
#   2. 填入真实 key 和差异值(见每段注释)
#   3. .env 已在 .gitignore 里,不会被 commit
#
# ⚠️ 本文件可 commit(只是模板,无真实 key)
# ============================================================


# ---------- 🔴 必需:LLM 模型 API Key ----------
# 主力: MiniMax (OpenAI 协议,api.minimaxi.com)
#   申请: https://minimaxi.com
MMX_API_KEY=

# 备用: Kimi K2.6 (Anthropic Messages 协议,api.kimi.com/coding/v1)
#   注意: 鉴权 header 是 `x-api-key`,不是 `Authorization: Bearer`
#   申请: https://kimi.com/coding
KIMI_API_KEY=

# LLM base URL(通常不用改,除非你用代理)
MMX_BASE_URL=https://api.minimaxi.com/v1
KIMI_BASE_URL=https://api.kimi.com/coding/v1
KIMI_MODEL=kimi-k2.6


# ---------- 🔴 必需:JWT 鉴权密钥 ----------
# ⚠️ 生产环境必须改成 32+ 位随机字符串
# 生成: python -c "import secrets; print(secrets.token_urlsafe(32))"
FASTINFO_SECRET=dev-only-not-secure-change-in-prod


# ---------- 🔴 必需:管理员初始密码 ----------
# 仅当 FASTINFO_INIT_ADMIN=1 时用于创建 admin 账号
# ⚠️ 生产环境首次部署后请立即通过前端修改密码
FASTINFO_ADMIN_PASSWORD=admin@2026


# ---------- 🟡 推荐 ----------
# 站点 URL(订阅推送消息底部「在网站查看」链接)
# 生产: https://kemi-ai.cn
# 本地开发: http://127.0.0.1:8080
# Docker 预发: http://127.0.0.1:18080
# 空字符串: 兜底 https://kemi-ai.cn/
FASTINFO_SITE_BASE=https://kemi-ai.cn


# ---------- 主机端口映射(本地开发默认) ----------
# 见 docs/ports-分配方案.md
# 本地默认(经典端口)
FASTINFO_API_PORT=8000        # L-API  (FastAPI)
FASTINFO_WEB_PORT=8080        # L-Web  (本地不起,留着对齐)
# Docker 预发默认(5 位数,跟本地完全错开,见 docker/env.docker.local.example)
# FASTINFO_API_PORT=18000
# FASTINFO_WEB_PORT=18080
# FASTINFO_MONGO_PORT=27018
# FASTINFO_REDIS_PORT=6380

# 源连续失败告警接收 webhook(可选)
# 例: 企业微信 / 飞书机器人 / Slack webhook
# 留空 = 不告警
FASTINFO_ALARM_WEBHOOK_URL=

# 国内 Docker 镜像加速前缀(可选)
# DOCKER_REGISTRY_PREFIX=docker.m.daocloud.io/library/


# ---------- 🟢 可选:通知渠道(不配就关) ----------
# SMTP 邮件推送(用 QQ 邮箱默认配置)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# 飞书(LARK)应用 - 推送 + OAuth 登录
LARK_APP_ID=
LARK_APP_SECRET=
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_REDIRECT_URI=http://127.0.0.1:8000/api/auth/feishu/callback


# ---------- 🟢 可选:仅测试用(生产留空) ----------
TEST_EMAIL=
TEST_FEISHU_WEBHOOK=
TEST_WECHAT_WEBHOOK=
TEST_WEBHOOK_URL=


# ============================================================
# ↓↓↓ 以下是【环境差异值】,本地开发 vs Docker 各填一份 ↓↓↓
# ============================================================
# 启动时 src/_env.py 自动 load 本文件;
# Docker compose 的 env_file 优先级**高于** .env,所以 Docker 会用 env.docker.local 覆盖下面这些。
#
# 本地默认值(直接用):
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB=fastinfo
REDIS_URL=redis://127.0.0.1:6379
DATA_DIR=./data
LANCEDB_DIR=./data/lancedb
APP_ENV=dev

# Docker 覆盖值(写在 docker/env.docker.local):
# MONGO_URL=mongodb://mongo:27017
# MONGO_DB=fastinfo_docker
# REDIS_URL=redis://redis:6379
# DATA_DIR=/app/data
# LANCEDB_DIR=/app/data/lancedb
# APP_ENV=prod   # P 正式环境必须标识为 prod;S 预发可改为 staging