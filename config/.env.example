# ============================================================
# fastInfo 环境变量样例(复制为 .env 后填入真实值)
# ============================================================

# ---------- AI 模型 ----------
# MiniMax-M3(主力) - OpenAI 协议 - https://minimaxi.com
MMX_API_KEY=
MMX_BASE_URL=https://api.minimaxi.com/v1

# Kimi K2.6(备用) - **Anthropic Messages 协议** - https://api.kimi.com/coding/v1
# 鉴权:header 用 `x-api-key`,而不是 `Authorization: Bearer`
KIMI_API_KEY=
KIMI_BASE_URL=https://api.kimi.com/coding/v1
KIMI_MODEL=kimi-k2.6

# ---------- 服务地址 ----------
REDIS_URL=redis://127.0.0.1:6379
MONGO_URL=mongodb://127.0.0.1:27017
QDRANT_URL=http://127.0.0.1:6333

# ---------- 数据存储 ----------
# 本地数据根目录(已在 .gitignore)
DATA_DIR=./data
LANCEDB_DIR=./data/lancedb

# ---------- 应用配置 ----------
APP_ENV=dev
APP_PORT=8080
LOG_LEVEL=info
