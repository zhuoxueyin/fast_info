# ============================================================
# fastInfo · 生产环境(阿里云 ECS)env 差异覆盖层
# ============================================================
# 用法:
#   cp docker/env.prod.local.example docker/env.prod.local
#   编辑 docker/env.prod.local 填入生产专用值(主要是 APP_ENV=prod + MONGO_DB=fastinfo_prod)
#
# 与 docker/env.docker.local 的区别:
#   docker/env.docker.local   ← 本机 Docker 预发(APP_ENV=docker, MONGO_DB=fastinfo_docker)
#   docker/env.prod.local     ← 云端 ECS 生产  (APP_ENV=prod,   MONGO_DB=fastinfo_prod)
#
# 加载优先级(docker compose,高→低):
#   1. services.*.environment      ← 显式(本文件 docker-compose.yml 不再用)
#   2. services.*.env_file         ← **本文件**(env.prod.local)
#   3. 项目根 .env 通过 volume 挂到 /app/.env,被 src/_env.py 用 load_dotenv 注入
#      (override=False,所以本文件的 env_file 优先)
#   4. 代码默认值
#
# ⚠️ 本文件含生产敏感信息(API Key 间接 + MONGO_DB),加进 .gitignore,绝不 commit。
# ============================================================


# ---------- 🔴 必需:环境身份 ----------
# 生产环境必须显式 APP_ENV=prod,**不能依赖**启发式(hostname 推断)
APP_ENV=prod
# 生产 db 名必须含 prod(防止部署脚本笔误连接到 dev / docker 的 db)
MONGO_DB=fastinfo_prod


# ---------- 容器内服务地址(同 docker,无需改) ----------
MONGO_URL=mongodb://mongo:27017
REDIS_URL=redis://redis:6379


# ---------- 数据目录(容器内固定) ----------
DATA_DIR=/app/data
LANCEDB_DIR=/app/data/lancedb


# ---------- 生产端口(可改,如对外 Nginx 反代) ----------
# 容器内 FastAPI 仍跑 8000,这里只暴露主机映射
# 注意:本机预发用 18080/18000,生产可以保留同样端口也可以用 80/8080
FASTINFO_WEB_PORT=18080
FASTINFO_API_PORT=18000
FASTINFO_MONGO_PORT=27018
FASTINFO_REDIS_PORT=6380


# ---------- 站点 URL(订阅推送消息里的"在 fastInfo 网站查看"链接) ----------
# 生产域名(必需,不能留空!)
FASTINFO_SITE_BASE=https://kemi-ai.cn


# ---------- 🔴 必需:JWT 鉴权密钥 ----------
# 生产必须改成 32+ 位随机字符串,**绝不复用** dev / docker 的值
# 生成: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ⚠️ 警告:此项也常放项目根 .env 共享,本文件只是为了提醒"生产必须独立"
# FASTINFO_SECRET=<production-only-32-char-random>


# ---------- 启动期管理 ----------
# FASTINFO_BOOTSTRAP=1: 容器首次启动时自动建 Mongo 索引
# FASTINFO_INIT_ADMIN=1: 若 admin 不存在则自动创建(幂等,已存在会跳过)
# 生产环境建议保持 1,但首次部署成功后务必修改默认 admin 密码
FASTINFO_BOOTSTRAP=1
FASTINFO_INIT_ADMIN=1
FASTINFO_ADMIN_USERNAME=admin
FASTINFO_ADMIN_PASSWORD=admin@2026


# ---------- 告警 webhook(可选) ----------
# 源连续失败告警接收 webhook
FASTINFO_ALARM_WEBHOOK_URL=


# ============================================================
# ↓↓↓ 以下是【共享配置】,通常走项目根 .env,这里只列差异 ↓↓↓
# ============================================================
# - MMX_API_KEY / KIMI_API_KEY    ← 放项目根 .env(共享)
# - SMTP_* / LARK_*                ← 放项目根 .env(共享)
# ============================================================