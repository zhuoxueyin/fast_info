# ============================================================
# fastInfo · Docker 模式"环境差异"覆盖层(本机预发 / 测试用)
# ============================================================
# 用法:
#   cp docker/env.docker.local.example docker/env.docker.local
#   编辑 docker/env.docker.local 填入差异值(主要是容器内服务名)
#
# ⚠️ 本文件适用于【本机预发 / 测试】,APP_ENV=docker。
#    生产 ECS 部署用【独立】的 docker/env.prod.local(APP_ENV=prod),
#    不要让 ECS 复用本文件,否则生产进程会拿到 APP_ENV=docker 而误判。
#
# 加载优先级(高到低):
#   1. docker-compose.yml 的 env_file(本文件)   ← 最高
#   2. /app/.env (项目根 .env 通过 volume 挂进来)
#   3. shell 环境变量
#   4. 代码里的默认值
#
# 所以这里**只填"本地 vs Docker 不一样"的值**,
# API Key / SECRET / SMTP 等共享值都从根 .env 来。
#
# ⚠️ 本文件含容器内服务地址,可能被误 commit,加进 .gitignore。
# ============================================================


# ---------- 容器内服务地址(必须改) ----------
# 注意:这里用 Docker 内部 DNS 名,不是 127.0.0.1
MONGO_URL=mongodb://mongo:27017
MONGO_DB=fastinfo_docker
REDIS_URL=redis://redis:6379

# ---------- 应用标识 ----------
# 本机预发用 docker。**生产 ECS 用 env.prod.local**,不要用本文件。
APP_ENV=docker

# ---------- 数据目录(容器内固定) ----------
DATA_DIR=/app/data
LANCEDB_DIR=/app/data/lancedb


# ---------- 端口映射(Docker 预发:5 位数 18xxx,本地 4 位数 8xxx,数据库 +1) ----------
# 见 docs/ports-分配方案.md
FASTINFO_WEB_PORT=18080   # S-Web  (Nginx)
FASTINFO_API_PORT=18000   # S-API  (FastAPI 直连)
FASTINFO_MONGO_PORT=27018 # S-Mongo(本地 27017)
FASTINFO_REDIS_PORT=6380  # S-Redis(本地 6379)


# ---------- Docker 启动期管理 ----------
# 首次启动自动建索引 + 初始化 admin 账号
# ⚠️ 生产环境请使用 docker/env.prod.local,不要复用本文件
FASTINFO_BOOTSTRAP=1
FASTINFO_INIT_ADMIN=1
FASTINFO_ADMIN_USERNAME=admin
FASTINFO_ADMIN_PASSWORD=admin@2026


# ============================================================
# ⚠️ 通常不要在本文件填的(走根 .env):
# - MMX_API_KEY / KIMI_API_KEY
# - FASTINFO_SECRET
# - FASTINFO_SITE_BASE
# - SMTP_*
# - LARK_*
# ============================================================