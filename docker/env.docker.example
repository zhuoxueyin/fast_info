# Copy values here or pass a separate --env-file when needed.
# These defaults are for local Docker Compose.

APP_ENV=docker
FASTINFO_SECRET=change-me-in-local-docker

# Optional registry prefix for networks where Docker Hub is slow/blocked.
# Example PowerShell:
#   $env:DOCKER_REGISTRY_PREFIX="docker.m.daocloud.io/library/"
DOCKER_REGISTRY_PREFIX=

MONGO_URL=mongodb://mongo:27017
MONGO_DB=fastinfo_docker
REDIS_URL=redis://redis:6379

# Optional: needed only for real LLM summarization / ingest.
MMX_API_KEY=
MMX_BASE_URL=https://api.minimaxi.com/v1
KIMI_API_KEY=
KIMI_BASE_URL=https://api.kimi.com/coding/v1
KIMI_MODEL=kimi-k2.6

DATA_DIR=/app/data
LANCEDB_DIR=/app/data/lancedb
